# App
APP_NAME=JobMatchingAPI
APP_VERSION=2.0.0
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/job_matching

# Redis
REDIS_URL=redis://localhost:6379/0
MATCH_CACHE_TTL=3600

# Embedding Model
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# HGAT Hyperparameters
HGAT_HIDDEN_DIM=128
HGAT_NUM_HEADS=4
HGAT_NUM_LAYERS=2
HGAT_DROPOUT=0.2
HGAT_LR=0.001
HGAT_BATCH_SIZE=16
HGAT_EPOCHS=3

# SLWG Weights
SLWG_EASY=0.1
SLWG_MEDIUM=0.3
SLWG_HARD=0.7

# Graph
JACCARD_THRESHOLD=0.3
FAISS_INDEX_TYPE=FlatIP
FAISS_TOP_K_CANDIDATES=50

# Translation
TRANSLATION_PROVIDER=argostranslate
